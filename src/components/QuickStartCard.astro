---
const { entry, href, locale = "en" } = Astro.props as {
  entry: {
    step: string;
    title: string;
    summary: string;
    bullets: string[];
  };
  href: string;
  locale?: string;
};
---

<article class="card quickstart-card">
  <p class="eyebrow">{entry.step}</p>
  <h3>{entry.title}</h3>
  <p>{entry.summary}</p>
  <ul class="card-bullets">
    {entry.bullets.slice(0, 3).map((item) => <li>{item}</li>)}
  </ul>
  <div class="cta-row">
    <a class="btn secondary card-link" href={href}>{locale === "zh" ? "打开指南" : "Open guide"}</a>
  </div>
</article>

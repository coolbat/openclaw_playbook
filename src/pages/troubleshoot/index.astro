---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/PageHero.astro";
import ArticleCard from "@/components/ArticleCard.astro";
import { getLocalizedCollection, getRouteSlug, getUniqueCategories } from "@/lib/content";
import { localizePath } from "@/lib/i18n";

const locale = "en";
const entries = await getLocalizedCollection("troubleshoot", locale);
const categories = getUniqueCategories(entries);
---

<BaseLayout active="troubleshoot" description="Symptom-first OpenClaw recovery guides for setup issues, runtime health, credentials, and workflow failures." locale={locale} path="/troubleshoot/" title="Troubleshoot | OpenClaw101">
  <PageHero
    className="page-hero hero-single"
    ctas={[
      { href: "#troubleshoot-directory", label: "Browse symptom groups", variant: "primary" },
      { href: localizePath("/#quick-start", locale), label: "Back to Quick Start", variant: "secondary" },
    ]}
    highlights={[
      `${entries.length} symptom-first entries`,
      "Start from what failed instead of making random guesses",
      "Narrow causes before changing setup, models, or workflows",
    ]}
    kicker="TROUBLESHOOT"
    summary="Use Troubleshoot as a diagnostic hub: start from what failed, narrow the likely causes, and only then change setup, models, or workflows."
    title="Diagnose OpenClaw by symptom, not by random guesses."
  />
  <div class="filter-rail" data-filter-group="troubleshoot" id="troubleshoot-directory">
    <button class="filter-button is-active" data-filter="all" type="button">All categories</button>
    {categories.map((category) => (
      <button class="filter-button" data-filter={category} type="button">{category}</button>
    ))}
  </div>
  <div class="grid cols-3">
    {entries.map((entry) => (
      <div data-filter-item={entry.data.category}>
        <ArticleCard eyebrow={entry.data.symptom} href={localizePath(`/troubleshoot/${getRouteSlug(entry)}/`, locale)} locale={locale} summary={entry.data.summary} title={entry.data.title} />
      </div>
    ))}
  </div>

  <script is:inline>
    (() => {
      const group = document.querySelector('[data-filter-group="troubleshoot"]');
      const items = Array.from(document.querySelectorAll("[data-filter-item]"));
      if (!(group instanceof HTMLElement) || items.length === 0) return;

      const buttons = Array.from(group.querySelectorAll("[data-filter]"));
      buttons.forEach((button) => {
        button.addEventListener("click", () => {
          if (!(button instanceof HTMLElement)) return;
          const value = button.dataset.filter ?? "all";
          buttons.forEach((item) => item.classList.toggle("is-active", item === button));
          items.forEach((item) => {
            if (!(item instanceof HTMLElement)) return;
            item.hidden = value !== "all" && item.dataset.filterItem !== value;
          });
        });
      });
    })();
  </script>
</BaseLayout>

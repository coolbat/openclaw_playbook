---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/PageHero.astro";
import ArticleCard from "@/components/ArticleCard.astro";
import { getLocalizedCollection, getRouteSlug, getUniqueCategories } from "@/lib/content";
import { localizePath } from "@/lib/i18n";

const locale = "en";
const entries = await getLocalizedCollection("learn", locale);
const categories = getUniqueCategories(entries);
---

<BaseLayout active="learn" description="Long-form OpenClaw guides for mental models, setup strategy, workflow design, and safer operating habits." locale={locale} path="/learn/" title="Learn | OpenClaw101">
  <PageHero
    className="page-hero hero-single"
    ctas={[
      { href: localizePath("/#quick-start", locale), label: "Review Quick Start", variant: "secondary" },
      { href: localizePath("/templates/", locale), label: "Browse starter templates", variant: "primary" },
    ]}
    highlights={[
      `${entries.length} starter articles`,
      "Foundations, setup strategy, workflow design, and Chinese ecosystem guidance",
      "Recovery paths and practical operating tips",
    ]}
    kicker="LEARN HUB"
    summary="Use Learn as your tutorial shelf for foundations, setup strategy, workflow design, Chinese ecosystem patterns, recovery paths, and day-to-day operating tips."
    title="Learn is the deeper OpenClaw resource hub."
  />
  <div class="filter-rail" data-filter-group="learn">
    <button class="filter-button is-active" data-filter="all" type="button">All categories</button>
    {categories.map((category) => (
      <button class="filter-button" data-filter={category} type="button">{category}</button>
    ))}
  </div>
  <div class="grid cols-3">
    {entries.map((entry) => (
      <div data-filter-item={entry.data.category}>
        <ArticleCard eyebrow={entry.data.category} href={localizePath(`/learn/${getRouteSlug(entry)}/`, locale)} locale={locale} summary={entry.data.summary} title={entry.data.title} />
      </div>
    ))}
  </div>

  <script is:inline>
    (() => {
      const group = document.querySelector('[data-filter-group="learn"]');
      const items = Array.from(document.querySelectorAll("[data-filter-item]"));
      if (!(group instanceof HTMLElement) || items.length === 0) return;

      const buttons = Array.from(group.querySelectorAll("[data-filter]"));
      buttons.forEach((button) => {
        button.addEventListener("click", () => {
          if (!(button instanceof HTMLElement)) return;
          const value = button.dataset.filter ?? "all";
          buttons.forEach((item) => item.classList.toggle("is-active", item === button));
          items.forEach((item) => {
            if (!(item instanceof HTMLElement)) return;
            item.hidden = value !== "all" && item.dataset.filterItem !== value;
          });
        });
      });
    })();
  </script>
</BaseLayout>

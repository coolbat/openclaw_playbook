---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/PageHero.astro";
import SkillsPanel from "@/components/SkillsPanel.astro";
import { skillsHero } from "@/config/skills";
import { localizePath } from "@/lib/i18n";

const locale = "en";
---

<BaseLayout active="skills" description="A curated set of OpenClaw skills organized by task category, with risk level and starter guidance." locale={locale} path="/skills/" title="Skills | OpenClaw101">
  <PageHero
    className="page-hero hero-single"
    ctas={[
      { href: "#skills-directory", label: "Browse by task category", variant: "primary" },
      { href: localizePath("/learn/choose-safer-starter-skills/", locale), label: "Read safety guide first", variant: "secondary" },
    ]}
    highlights={[
      "Research, content, productivity, DevOps, communications, and Chinese ecosystem",
      "Risk level and starter guidance included",
      "Curated rather than marketplace-style",
    ]}
    kicker={skillsHero.kicker}
    summary={skillsHero.summary.en}
    title={skillsHero.title.en}
  />
  <div id="skills-directory">
    <SkillsPanel locale={locale} />
  </div>
</BaseLayout>

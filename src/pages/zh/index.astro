---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/PageHero.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import QuickStartCard from "@/components/QuickStartCard.astro";
import ArticleCard from "@/components/ArticleCard.astro";
import { adsConfig, isAdSlotEnabled } from "@/config/ads";
import { homeConfig } from "@/config/home";
import { getLocalizedCollection, getRouteSlug } from "@/lib/content";
import { localizePath } from "@/lib/i18n";

const locale = "zh";
const quickStart = await getLocalizedCollection("quickStart", locale);
const learnEntries = await getLocalizedCollection("learn", locale);
const templateEntries = await getLocalizedCollection("templates", locale);
const troubleshootEntries = await getLocalizedCollection("troubleshoot", locale);
const learn = learnEntries.slice(0, 3);
const templates = templateEntries.slice(0, 3);
const troubleshoot = troubleshootEntries.slice(0, 3);
const homeAd = adsConfig.slots.home_between_sections.content.zh;
---

<BaseLayout
  active="home"
  description={homeConfig.hero.summary.zh}
  locale={locale}
  path="/"
  title="AnyPlaybook | 教程站模板"
>
  <PageHero
    className="hero"
    ctas={[
      { href: "#quick-start", label: "进入 5 步 Quick Start", variant: "primary" },
      { href: localizePath("/learn/", locale), label: "浏览 Learn", variant: "secondary" },
    ]}
    highlights={[
      "内置中英双语路由",
      "深浅色与语言切换就绪",
      "内容集合结构已整理",
    ]}
    kicker={homeConfig.hero.kicker}
    summary={homeConfig.hero.summary.zh}
    title={homeConfig.hero.title.zh}
    aside={homeConfig.hero.aside.zh}
  />

  <section class="section" id="quick-start">
    <SectionHeading title={homeConfig.quickStartIntro.title.zh} summary={homeConfig.quickStartIntro.summary.zh} />
    <div class="grid cols-2">
      {quickStart.map((entry) => (
        <QuickStartCard entry={entry.data} href={localizePath(`/quick-start/${getRouteSlug(entry)}/`, locale)} />
      ))}
    </div>
  </section>

  <section class="section">
    <SectionHeading
      actionHref={localizePath("/learn/", locale)}
      actionLabel={`进入 Learn 资源中心（${learnEntries.length} 篇）`}
      summary={homeConfig.learnIntro.summary.zh}
      title={homeConfig.learnIntro.title.zh}
    />
    <div class="grid cols-3">
      {learn.map((entry) => (
        <ArticleCard
          eyebrow={entry.data.category}
          href={localizePath(`/learn/${getRouteSlug(entry)}/`, locale)}
          summary={entry.data.summary}
          title={entry.data.title}
        />
      ))}
    </div>
  </section>

  {isAdSlotEnabled("home_between_sections") && (
    <section class="ad-preview-banner section">
      <div class="ad-preview-copy">
        <p class="eyebrow">{homeAd.label}</p>
        <h2>{homeAd.title}</h2>
        <p>{homeAd.summary}</p>
      </div>
      <a class="btn secondary ad-preview-action" href={localizePath(homeAd.href, locale)}>
        {homeAd.ctaLabel}
      </a>
    </section>
  )}

  <section class="section">
    <SectionHeading
      actionHref={localizePath("/templates/", locale)}
      actionLabel={`浏览模板（${templateEntries.length} 个）`}
      summary={homeConfig.templatesIntro.summary.zh}
      title={homeConfig.templatesIntro.title.zh}
    />
    <div class="grid cols-3">
      {templates.map((entry) => (
        <ArticleCard
          eyebrow={`${entry.data.difficulty} · ${entry.data.time}`}
          href={localizePath(`/templates/${getRouteSlug(entry)}/`, locale)}
          summary={entry.data.summary}
          title={entry.data.title}
        />
      ))}
    </div>
  </section>

  <section class="section">
    <SectionHeading
      actionHref={localizePath("/troubleshoot/", locale)}
      actionLabel={`进入排错库（${troubleshootEntries.length} 篇）`}
      summary={homeConfig.troubleshootIntro.summary.zh}
      title={homeConfig.troubleshootIntro.title.zh}
    />
    <div class="grid cols-3">
      {troubleshoot.map((entry) => (
        <ArticleCard
          eyebrow={entry.data.symptom}
          href={localizePath(`/troubleshoot/${getRouteSlug(entry)}/`, locale)}
          summary={entry.data.summary}
          title={entry.data.title}
        />
      ))}
    </div>
  </section>
</BaseLayout>

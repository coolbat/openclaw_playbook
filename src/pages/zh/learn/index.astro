---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/PageHero.astro";
import ArticleCard from "@/components/ArticleCard.astro";
import { getLocalizedCollection, getRouteSlug, getUniqueCategories } from "@/lib/content";
import { localizePath } from "@/lib/i18n";

const locale = "zh";
const entries = await getLocalizedCollection("learn", locale);
const categories = getUniqueCategories(entries);
---

<BaseLayout active="learn" description="Learn 资源中心模板页。" locale={locale} path="/learn/" title="Learn | AnyPlaybook">
  <PageHero
    className="page-hero hero-single"
    highlights={[
      `${entries.length} 篇示例长文`,
      "已内置面包屑与上下文导航",
      "支持草稿与时间元数据",
    ]}
    kicker="LEARN HUB"
    summary="用于概念、策略、工作流设计和更稳使用习惯的长文栏目。"
    title="先理解，再扩展。"
  />
  <div class="filter-rail" data-filter-group="learn">
    <button class="filter-button is-active" data-filter="all" type="button">全部分类</button>
    {categories.map((category) => (
      <button class="filter-button" data-filter={category} type="button">{category}</button>
    ))}
  </div>
  <div class="grid cols-3">
    {entries.map((entry) => (
      <div data-filter-item={entry.data.category}>
        <ArticleCard eyebrow={entry.data.category} href={localizePath(`/learn/${getRouteSlug(entry)}/`, locale)} summary={entry.data.summary} title={entry.data.title} />
      </div>
    ))}
  </div>

  <script is:inline>
    (() => {
      const group = document.querySelector('[data-filter-group="learn"]');
      const items = Array.from(document.querySelectorAll("[data-filter-item]"));
      if (!(group instanceof HTMLElement) || items.length === 0) return;

      const buttons = Array.from(group.querySelectorAll("[data-filter]"));
      buttons.forEach((button) => {
        button.addEventListener("click", () => {
          if (!(button instanceof HTMLElement)) return;
          const value = button.dataset.filter ?? "all";
          buttons.forEach((item) => item.classList.toggle("is-active", item === button));
          items.forEach((item) => {
            if (!(item instanceof HTMLElement)) return;
            item.hidden = value !== "all" && item.dataset.filterItem !== value;
          });
        });
      });
    })();
  </script>
</BaseLayout>

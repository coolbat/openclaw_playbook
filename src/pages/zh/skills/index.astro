---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/PageHero.astro";
import SkillsPanel from "@/components/SkillsPanel.astro";
import { skillsHero } from "@/config/skills";
import { localizePath } from "@/lib/i18n";

const locale = "zh";
---

<BaseLayout active="skills" description="按任务类别精选的 OpenClaw 技能集合，附带风险等级和新手建议。" locale={locale} path="/skills/" title="Skills | OpenClaw101">
  <PageHero
    className="page-hero hero-single"
    ctas={[
      { href: "#skills-directory", label: "按任务类别浏览", variant: "primary" },
      { href: localizePath("/learn/choose-safer-starter-skills/", locale), label: "先读安全指南", variant: "secondary" },
    ]}
    highlights={[
      "覆盖调研、内容、效率、DevOps、通信与中文生态",
      "附带风险等级和新手建议",
      "精选集合，不是全量技能商店",
    ]}
    kicker={skillsHero.kicker}
    summary={skillsHero.summary.zh}
    title={skillsHero.title.zh}
  />
  <div id="skills-directory">
    <SkillsPanel locale={locale} />
  </div>
</BaseLayout>

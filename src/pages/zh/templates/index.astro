---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/PageHero.astro";
import ArticleCard from "@/components/ArticleCard.astro";
import { getLocalizedCollection, getRouteSlug, getUniqueCategories } from "@/lib/content";
import { localizePath } from "@/lib/i18n";

const locale = "zh";
const entries = await getLocalizedCollection("templates", locale);
const categories = getUniqueCategories(entries);
---

<BaseLayout active="templates" description="按工作目标组织的 OpenClaw 起步模板库，覆盖简报、协作、调研、监控和内容生产。" locale={locale} path="/templates/" title="Templates | OpenClaw101">
  <PageHero
    className="page-hero hero-single"
    ctas={[
      { href: "#templates-directory", label: "按工作目标浏览", variant: "primary" },
      { href: localizePath("/#quick-start", locale), label: "先回看 Quick Start", variant: "secondary" },
    ]}
    highlights={[
      `${entries.length} 个起步模板`,
      "包含难度、耗时、风险和渠道建议",
      "覆盖信息简报、内容生产、团队协作、调研和监控",
    ]}
    kicker="TEMPLATE LIBRARY"
    summary="把 Templates 当成一个可落地的起点目录：从信息简报、内容生产、团队协作、调研分析、监控告警到中文生态工作流，都按工作目标组织起来。"
    title="按工作目标组织的起步模板库。"
  />
  <div class="filter-rail" data-filter-group="templates" id="templates-directory">
    <button class="filter-button is-active" data-filter="all" type="button">全部分类</button>
    {categories.map((category) => (
      <button class="filter-button" data-filter={category} type="button">{category}</button>
    ))}
  </div>
  <div class="grid cols-3">
    {entries.map((entry) => (
      <div data-filter-item={entry.data.category}>
        <ArticleCard eyebrow={`${entry.data.difficulty} · ${entry.data.time}`} href={localizePath(`/templates/${getRouteSlug(entry)}/`, locale)} locale={locale} summary={entry.data.summary} title={entry.data.title} />
      </div>
    ))}
  </div>

  <script is:inline>
    (() => {
      const group = document.querySelector('[data-filter-group="templates"]');
      const items = Array.from(document.querySelectorAll("[data-filter-item]"));
      if (!(group instanceof HTMLElement) || items.length === 0) return;

      const buttons = Array.from(group.querySelectorAll("[data-filter]"));
      buttons.forEach((button) => {
        button.addEventListener("click", () => {
          if (!(button instanceof HTMLElement)) return;
          const value = button.dataset.filter ?? "all";
          buttons.forEach((item) => item.classList.toggle("is-active", item === button));
          items.forEach((item) => {
            if (!(item instanceof HTMLElement)) return;
            item.hidden = value !== "all" && item.dataset.filterItem !== value;
          });
        });
      });
    })();
  </script>
</BaseLayout>

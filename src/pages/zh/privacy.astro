---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getEntryBySlug } from "@/lib/content";

const entry = await getEntryBySlug("pages", "zh", "privacy");
if (!entry) {
  throw new Error('Missing "privacy" page content for locale "zh".');
}

const { Content } = await entry.render();
---

<BaseLayout active="none" description={entry.data.summary} locale="zh" path="/privacy/" title={`${entry.data.title} | OpenClaw101`}>
  <article class="section card page-prose" data-pagefind-body>
    <h1>{entry.data.title}</h1>
    <p class="sub">{entry.data.summary}</p>
    <Content />
  </article>
</BaseLayout>

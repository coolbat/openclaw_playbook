---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/PageHero.astro";
import ArticleCard from "@/components/ArticleCard.astro";
import { getLocalizedCollection, getRouteSlug, getUniqueCategories } from "@/lib/content";
import { localizePath } from "@/lib/i18n";

const locale = "en";
const entries = await getLocalizedCollection("templates", locale);
const categories = getUniqueCategories(entries);
---

<BaseLayout active="templates" description="Starter workflow templates for OpenClaw briefings, research, collaboration, monitoring, and content production." locale={locale} path="/templates/" title="Templates | OpenClaw101">
  <PageHero
    className="page-hero hero-single"
    ctas={[
      { href: "#templates-directory", label: "Browse by work goal", variant: "primary" },
      { href: localizePath("/#quick-start", locale), label: "Review Quick Start first", variant: "secondary" },
    ]}
    highlights={[
      `${entries.length} starter templates`,
      "Difficulty, time, risk, and channel guidance",
      "Briefings, content production, collaboration, research, and monitoring",
    ]}
    kicker="TEMPLATE LIBRARY"
    summary="Use Templates as a directory of practical starting points: briefings, content production, collaboration, research, monitoring, and Chinese ecosystem workflows."
    title="Templates organized by the work you want done."
  />
  <div class="filter-rail" data-filter-group="templates" id="templates-directory">
    <button class="filter-button is-active" data-filter="all" type="button">All categories</button>
    {categories.map((category) => (
      <button class="filter-button" data-filter={category} type="button">{category}</button>
    ))}
  </div>
  <div class="grid cols-3">
    {entries.map((entry) => (
      <div data-filter-item={entry.data.category}>
        <ArticleCard eyebrow={`${entry.data.difficulty} · ${entry.data.time}`} href={localizePath(`/templates/${getRouteSlug(entry)}/`, locale)} locale={locale} summary={entry.data.summary} title={entry.data.title} />
      </div>
    ))}
  </div>

  <script is:inline>
    (() => {
      const group = document.querySelector('[data-filter-group="templates"]');
      const items = Array.from(document.querySelectorAll("[data-filter-item]"));
      if (!(group instanceof HTMLElement) || items.length === 0) return;

      const buttons = Array.from(group.querySelectorAll("[data-filter]"));
      buttons.forEach((button) => {
        button.addEventListener("click", () => {
          if (!(button instanceof HTMLElement)) return;
          const value = button.dataset.filter ?? "all";
          buttons.forEach((item) => item.classList.toggle("is-active", item === button));
          items.forEach((item) => {
            if (!(item instanceof HTMLElement)) return;
            item.hidden = value !== "all" && item.dataset.filterItem !== value;
          });
        });
      });
    })();
  </script>
</BaseLayout>
